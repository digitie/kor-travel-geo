# kor-travel-geo 개발(dev) 환경값 — 예시(placeholder)
#
# 별도 지시가 없으면 dev 환경이 기본이다(prod는 `.env.prod` + kor-travel-docker-manager + 공식 도메인).
# dev는 이 저장소에서 직접 실행(uvicorn/npm)하거나 `docker_app.sh`(host 네트워크 모드)로 띄운다.
# 모든 내부 주소는 루프백 `127.0.0.1`, 앱 포트는 12xxx(API 12501 / UI 12505)다.
#
# 사용:
#   - docker_app.sh:  KTG_ENV_FILE=.env.dev scripts/docker_app.sh up   (기본 host 네트워크 모드)
#   - 직접 실행:       이 파일을 참고해 루트 `.env` / `kor-travel-geo-ui/.env.local`을 채운다.
#
# 형식 규칙(docker `--env-file` 호환): 전체 줄 주석(`#`)만, 값 뒤 inline 주석 금지.

# --- DB / RustFS: 127.0.0.1에 게시된 공용 인프라(예: kor-travel-docker-manager)에 접속 ---
KTG_PG_DSN=postgresql+psycopg://addr:addr@127.0.0.1:5432/kor_travel_geo
KTG_RUSTFS_ENABLED=false
KTG_RUSTFS_ENDPOINT_URL=http://127.0.0.1:12101
KTG_RUSTFS_BUCKET=kor-travel-geo
KTG_RUSTFS_PREFIX=kor-travel-geo
KTG_RUSTFS_REGION=us-east-1
# RustFS console(운영자 UI, 앱 변수 아님): http://127.0.0.1:12105

# --- 앱(API/UI): dev 포트 12xxx, 내부 주소 127.0.0.1 ---
# UI 서버사이드 프록시 → API (host 네트워크 모드에서 127.0.0.1:12501)
KTG_API_INTERNAL_URL=http://127.0.0.1:12501
NEXT_PUBLIC_API_BASE_URL=/api/proxy
KTG_API_CORS_ORIGINS=[]
KTG_PUBLIC_API_KEY_CACHE_TTL_S=30

# --- GeoIP: dev는 보통 off(로컬/폐쇄망). 실제 차단 테스트 시 strict. ---
KTG_GEOIP_GATE_MODE=off
KTG_ADMIN_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# --- 비밀값: 로컬에서만 채운다(커밋 금지) ---
# KTG_VWORLD_API_KEY=<key>
# KTG_ADMIN_PROXY_SECRET=<random-shared-secret>
# KTG_RUSTFS_ACCESS_KEY=<key>
# KTG_RUSTFS_SECRET_KEY=<key>
