# kor-travel-geo 운영(prod) 환경값 — 예시(placeholder)
#
# 실제 도메인/비밀값은 이 파일이 아니라 gitignored `.env.prod`(또는 배포 노드의
# `/etc/kor-travel-geo/app.env`)에 둔다. 이 `.example`만 git에 추적되며, 실제 값은
# 절대 커밋하지 않는다(외부 노출 금지).
#
# 두 배포 경로가 같은 파일을 공유한다:
#   - deploy_app.py:  실제 값 파일을 노드의 `/etc/kor-travel-geo/app.env`로 두고
#                     `--remote-env-file`로 주입(docker `--env-file`).
#   - docker_app.sh:  `KTG_ENV_FILE=.env.prod scripts/docker_app.sh up`
#
# 형식 규칙(docker `--env-file` 호환):
#   - 전체 줄 주석(`#`)만 허용. 값 뒤 inline 주석 금지.
#   - JSON 리스트는 따옴표째 그대로: KTG_API_CORS_ORIGINS=["https://..."]

# --- 도메인 (리버스 프록시가 TLS 종단) ---
# UI 서버사이드 프록시 → API. 컨테이너가 같은 docker 네트워크에 co-located면
# http://kor-travel-geo-api:12501 이 더 빠르다(공개 도메인은 hairpin).
KTG_API_INTERNAL_URL=https://<geo-api-host>
# API CORS 허용 origin. UI는 same-origin `/api/proxy`를 쓰므로 보통 선택적이지만,
# 브라우저가 API를 직접 호출하는 경우를 대비해 UI 공개 origin을 넣어 둔다.
KTG_API_CORS_ORIGINS=["https://<geo-ui-host>"]
NEXT_PUBLIC_API_BASE_URL=/api/proxy
KTG_PUBLIC_API_KEY_CACHE_TTL_S=30

# --- RustFS / S3 (prod) ---
KTG_RUSTFS_ENABLED=true
KTG_RUSTFS_ENDPOINT_URL=https://<s3-api-host>
KTG_RUSTFS_BUCKET=kor-travel-geo
KTG_RUSTFS_PREFIX=kor-travel-geo
KTG_RUSTFS_REGION=us-east-1
# RustFS console(운영자 UI, 앱 변수 아님): https://<s3-console-host>

# --- 운영 기본 ---
KTG_GEOIP_GATE_MODE=strict
KTG_ADMIN_TRUSTED_PROXY_CIDRS=<reverse-proxy-cidr>

# --- 비밀값: 배포 호스트/노드에서만 채운다(커밋 금지) ---
# KTG_PG_DSN=postgresql+psycopg://<user>:<pass>@<db-host>:5432/kor_travel_geo
# KTG_VWORLD_API_KEY=<key>
# KTG_ADMIN_PROXY_SECRET=<random-shared-secret>
# KTG_RUSTFS_ACCESS_KEY=<key>
# KTG_RUSTFS_SECRET_KEY=<key>
