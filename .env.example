# PostgreSQL + PostGIS
KRADDR_GEO_PG_DSN=postgresql+psycopg://addr:addr@localhost:5432/kraddr_geo
KRADDR_GEO_PG_POOL_SIZE=10
KRADDR_GEO_PG_MAX_OVERFLOW=5
KRADDR_GEO_PG_STATEMENT_TIMEOUT_MS=5000
KRADDR_GEO_PG_POOL_RECYCLE_S=3600

# REST API
KRADDR_GEO_API_TITLE=kraddr-geo
KRADDR_GEO_API_CORS_ORIGINS=[]
KRADDR_GEO_API_DEFAULT_RADIUS_M=200
KRADDR_GEO_API_MAX_SEARCH_SIZE=100
KRADDR_GEO_API_MAX_UPLOAD_BYTES=2147483648
KRADDR_GEO_API_EXPLAIN_TIMEOUT_MS=3000
KRADDR_GEO_API_ADMISSION_TIMEOUT_MS=30000
# unset이면 비활성화. 설정하면 /v1/address/* 요청을 process별로 제한한다.
# KRADDR_GEO_API_MAX_CONCURRENCY=16

# External API fallback keys
KRADDR_GEO_JUSO_API_KEY=
KRADDR_GEO_JUSO_COORD_API_KEY=
KRADDR_GEO_VWORLD_API_KEY=
# data.go.kr 데이터셋 15000302 (우편번호 다운로드 서비스, 분기 1회 전체 적재 — ADR-009)
KRADDR_GEO_EPOST_API_KEY=

# External API endpoints
KRADDR_GEO_JUSO_SEARCH_URL=https://business.juso.go.kr/addrlink/addrLinkApi.do
KRADDR_GEO_JUSO_COORD_URL=https://business.juso.go.kr/addrlink/addrCoordApi.do
KRADDR_GEO_VWORLD_URL=https://api.vworld.kr/req/address
KRADDR_GEO_EPOST_DOWNLOAD_URL=http://openapi.epost.go.kr/postal/downloadAreaCodeService/downloadAreaCodeService/getAreaCodeInfo

# Cache / logging / loader
KRADDR_GEO_CACHE_ENABLED=true
KRADDR_GEO_CACHE_TTL_DAYS=30
KRADDR_GEO_LOG_LEVEL=INFO
KRADDR_GEO_LOG_FORMAT=json
KRADDR_GEO_LOADER_DATA_DIR=data
KRADDR_GEO_LOADER_BATCH_SIZE=5000
KRADDR_GEO_LOADER_TEMP_SCHEMA=staging

# DB backup / restore
# 서버 프로세스가 접근할 수 있는 allowlist 경로만 백업 저장/복원 입력으로 허용한다.
KRADDR_GEO_BACKUP_ALLOWED_DIRS=data/backups
KRADDR_GEO_BACKUP_TEMP_DIR=/tmp/kraddr-geo-backup
KRADDR_GEO_BACKUP_DEFAULT_JOBS=4
KRADDR_GEO_BACKUP_DEFAULT_COMPRESSION_LEVEL=3
KRADDR_GEO_BACKUP_ARTIFACT_TTL_DAYS=30
KRADDR_GEO_BACKUP_CALLBACK_ALLOWED_HOSTS=localhost,127.0.0.1,::1
# 비우면 설정값과 artifact metadata 기반 fallback secret으로 HMAC download token을 만든다.
KRADDR_GEO_BACKUP_DOWNLOAD_TOKEN_SECRET=
