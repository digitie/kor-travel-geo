# PostgreSQL + PostGIS
KTG_PG_DSN=postgresql+psycopg://addr:addr@localhost:5432/kor_travel_geo
KTG_PG_POOL_SIZE=10
KTG_PG_MAX_OVERFLOW=5
KTG_PG_STATEMENT_TIMEOUT_MS=5000
KTG_PG_SEARCH_PATH=public,x_extension
KTG_PG_POOL_RECYCLE_S=3600

# REST API
KTG_API_TITLE=kor-travel-geo
KTG_API_CORS_ORIGINS=[]
KTG_API_DEFAULT_RADIUS_M=200
KTG_API_MAX_SEARCH_SIZE=100
KTG_API_MAX_UPLOAD_BYTES=2147483648
KTG_API_EXPLAIN_TIMEOUT_MS=3000
KTG_API_ADMISSION_TIMEOUT_MS=30000
# unset이면 비활성화. 설정하면 /v1/address/* 요청을 process별로 제한한다.
# KTG_API_MAX_CONCURRENCY=16
KTG_API_PERFORMANCE_LOGGING_ENABLED=false
KTG_API_SLOW_REQUEST_MS=500
KTG_PG_QUERY_METRICS_ENABLED=true
# Prometheus는 pull 방식이다. kor-travel-docker-manager 기준 Prometheus/Grafana/cAdvisor host 포트는 12401/12205/12301이고,
# scrape 대상은 API /metrics와 UI /api/metrics다.
# 로컬 단독 실행: http://127.0.0.1:12501/metrics, http://127.0.0.1:12505/api/metrics
# manager compose: kor-travel-geo-api:12501/metrics, kor-travel-geo-ui:12505/api/metrics

# Korea-only GeoIP gate (T-054)
# strict: GeoIP DB가 없으면 외부 공용 IP를 차단한다. off는 테스트/폐쇄망에서만 사용한다.
KTG_GEOIP_GATE_MODE=strict
KTG_GEOIP_DB_PATH=data/geoip/GeoLite2-Country.mmdb
KTG_GEOIP_OPEN_PATHS=/v1/healthz,/metrics
KTG_GEOIP_ALLOW_CIDRS=
KTG_GEOIP_DENY_CIDRS=
KTG_GEOIP_TRUSTED_PROXIES=
KTG_GEOIP_AUDIT_DENIALS=true

# External API fallback keys
KTG_JUSO_API_KEY=
KTG_JUSO_COORD_API_KEY=
KTG_VWORLD_API_KEY=
# data.go.kr 데이터셋 15000302 (우편번호 다운로드 서비스, 분기 1회 전체 적재 — ADR-009)
KTG_EPOST_API_KEY=

# External API endpoints
KTG_JUSO_SEARCH_URL=https://business.juso.go.kr/addrlink/addrLinkApi.do
KTG_JUSO_COORD_URL=https://business.juso.go.kr/addrlink/addrCoordApi.do
KTG_VWORLD_URL=https://api.vworld.kr/req/address
KTG_EPOST_DOWNLOAD_URL=http://openapi.epost.go.kr/postal/downloadAreaCodeService/downloadAreaCodeService/getAreaCodeInfo

# Cache / logging / loader
KTG_CACHE_ENABLED=true
KTG_CACHE_TTL_DAYS=30
KTG_LOG_LEVEL=INFO
KTG_LOG_FORMAT=json
KTG_LOADER_DATA_DIR=data
KTG_LOADER_BATCH_SIZE=5000
KTG_LOADER_TEMP_SCHEMA=staging
KTG_UPLOAD_SET_TTL_DAYS=30
KTG_UPLOAD_SET_ACTIVE_GRACE_MINUTES=360
# 0이면 비활성화. 활성화하면 API 프로세스가 주기적으로 ops.table_stats_snapshots를 기록한다.
KTG_OPS_TABLE_STATS_CAPTURE_INTERVAL_MINUTES=0
KTG_OPS_TABLE_STATS_CAPTURE_LIMIT=500
KTG_OPS_TABLE_STATS_CAPTURE_ON_STARTUP=false

# RustFS / S3 호환 bucket 접속 설정
# 이 프로젝트는 RustFS를 직접 구동하지 않는다. 이미 동작 중인 bucket에 접속한다.
# kor-travel-docker-manager 기준 RustFS host 포트는 S3 API 12101, console 12105다.
KTG_RUSTFS_ENABLED=false
KTG_RUSTFS_ENDPOINT_URL=http://127.0.0.1:12101
KTG_RUSTFS_BUCKET=kor-travel-geo
KTG_RUSTFS_REGION=us-east-1
KTG_RUSTFS_PREFIX=kor-travel-geo
KTG_RUSTFS_ACCESS_KEY=
KTG_RUSTFS_SECRET_KEY=
KTG_RUSTFS_RETENTION_DAYS=0
KTG_RUSTFS_LOCAL_IMPORT_ROOTS=data

# DB backup / restore
# 서버 프로세스가 접근할 수 있는 allowlist 경로만 백업 저장/복원 입력으로 허용한다.
KTG_BACKUP_ALLOWED_DIRS=data/backups
KTG_BACKUP_TEMP_DIR=/tmp/kor-travel-geo-backup
KTG_BACKUP_DEFAULT_JOBS=4
KTG_BACKUP_DEFAULT_COMPRESSION_LEVEL=3
KTG_BACKUP_ARTIFACT_TTL_DAYS=30
KTG_BACKUP_CALLBACK_ALLOWED_HOSTS=localhost,127.0.0.1,::1
KTG_BACKUP_CALLBACK_MAX_ATTEMPTS=3
KTG_BACKUP_CALLBACK_BACKOFF_MS=500
# 비우면 download token secret 또는 DSN 기반 fallback secret으로 callback HMAC을 만든다.
KTG_BACKUP_CALLBACK_SECRET=
# 비우면 설정값과 artifact metadata 기반 fallback secret으로 HMAC download token을 만든다.
KTG_BACKUP_DOWNLOAD_TOKEN_SECRET=
