# 로컬 개발 기본값. 운영(prod)에서는 API 공개 도메인(예: https://<geo-api-host>)을 쓰며,
# 실제 prod 값은 gitignored `.env.prod` 또는 배포 노드 app.env에 둔다(루트 `.env.prod.example` 참고).
KTG_API_INTERNAL_URL=http://localhost:12501
NEXT_PUBLIC_API_BASE_URL=/api/proxy
NEXT_PUBLIC_VWORLD_API_KEY=your_vworld_api_key

# Admin UI 로그인/프록시. 실제 password hash와 secret은 gitignored `.env.local`에만 둔다.
KTG_UI_ADMIN_USERNAME=admin
KTG_UI_ADMIN_PASSWORD_HASH=pbkdf2_sha256$310000$<salt>$<hash>
KTG_UI_SESSION_SECRET=<random-session-secret>
KTG_ADMIN_PROXY_SECRET=<same-random-shared-secret-as-api>
# Number of trusted reverse proxies in front of the UI. Login rate-limiting + audit only trust
# X-Forwarded-For when this is >= 1 (reading the Nth entry from the right of the appended chain).
# Leave 0 when the UI is reached directly (XFF is then untrusted and not used for the client IP).
KTG_UI_TRUSTED_PROXY_HOPS=0
# Trusted public browser origins for login CSRF checks when a TLS-terminating proxy does not
# provide X-Forwarded-Proto. Leave empty for local direct access.
KTG_UI_PUBLIC_ORIGINS=
